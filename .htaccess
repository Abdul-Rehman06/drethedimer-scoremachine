Options -MultiViews

RewriteEngine On

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteCond %{DOCUMENT_ROOT}/dist/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/dist/$1 -d
RewriteRule ^(.*)$ dist/$1 [L]

RewriteCond %{DOCUMENT_ROOT}/.output/public/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/.output/public/$1 -d
RewriteRule ^(.*)$ .output/public/$1 [L]

RewriteCond %{DOCUMENT_ROOT}/dist/index.html -f
RewriteRule ^ dist/index.html [L]

RewriteCond %{DOCUMENT_ROOT}/.output/public/index.html -f
RewriteRule ^ .output/public/index.html [L]
